# EduSexual PT - Variáveis de Ambiente
# Copie este ficheiro para .env.local e preencha os valores

# Stitch AI (para geração de áudio)
STITCH_API_KEY=your_api_key_here
STITCH_PROJECT_ID=your_project_id_here

# Telegram Bot (para perguntas anónimas)
TELEGRAM_BOT_TOKEN=your_botfather_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Gemini API (opcional - para geração de áudio alternativa)
GEMINI_API_KEY=your_gemini_api_key_here
